OPENAI_API_KEY=replace-with-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=bge-m3
DOCUMENTS_DIR=data/documents
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=rag_knowledge_base
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=4
BM25_CORPUS_PATH=data/chroma/bm25_corpus.jsonl
DENSE_RETRIEVAL_TOP_K=20
BM25_RETRIEVAL_TOP_K=20
RRF_K=60
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=5
PARENT_CORPUS_PATH=data/chroma/parent_corpus.jsonl
PARENT_CHUNK_SIZE=2048
PARENT_CHUNK_OVERLAP=160
QUERY_REWRITE_ENABLED=true
HYDE_ENABLED=true
MAX_QUERY_VARIANTS=4
QUERY_TRANSFORM_TIMEOUT_SECONDS=8
MIN_RERANKER_SCORE=-5.0
MIN_FINAL_SOURCE_COUNT=1
ENABLE_LOW_CONFIDENCE_REFUSAL=true
TIME_SENSITIVE_REFUSAL_ENABLED=true
EVAL_DATASET_PATH=data/eval/sample_eval.jsonl
MAX_QUESTION_CHARS=2000
LLM_TIMEOUT_SECONDS=60
ANSWER_CACHE_ENABLED=false
ANSWER_CACHE_BACKEND=redis
ANSWER_CACHE_TTL_SECONDS=300
REDIS_URL=redis://localhost:6379/0
AUTH_ENABLED=false
ADMIN_API_KEYS=
DEFAULT_TENANT_ID=default
AUDIT_DB_PATH=data/runtime/audit.sqlite3
AUDIT_QUESTION_MAX_CHARS=500
AUDIT_ANSWER_MAX_CHARS=1000
PERMISSION_VERSION=local-v1
DOCUMENTS_MANIFEST_PATH=data/documents_manifest.json
DOCUMENT_INDEX_VERSION=local-index-v1
# Versioned indexes are opt-in. INDEX_ROOT_DIR and ACTIVE_INDEX_VERSION_PATH
# are used only when VERSIONED_INDEXING_ENABLED=true.
VERSIONED_INDEXING_ENABLED=false
INDEX_ROOT_DIR=data/indexes
ACTIVE_INDEX_VERSION_PATH=data/indexes/active_version.txt
INGESTION_MODE=sync
PERMISSION_FILTER_OVERFETCH_MAX=100
WECOM_ENABLED=false
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CALLBACK_PATH=/integrations/wecom/callback
WECOM_RESPONSE_MODE=active
WECOM_USER_MAPPING_PATH=data/runtime/wecom_users.json
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com/cgi-bin
WECOM_REQUEST_TIMEOUT_SECONDS=8
WECOM_RETRY_COUNT=2
